rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Relaxed helpers for "free resource" authentication
    function isOwner(userId) {
      // Allow real Firebase Auth users OR mock "local" users
      return (isSignedIn() && request.auth.uid == userId) || userId.startsWith('local_');
    }

    function isDataOwner(data) {
      return (isSignedIn() && data.userId == request.auth.uid) || data.userId.startsWith('local_');
    }

    // User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(incoming(), userId);
      allow update: if isOwner(userId) && isValidUserProfile(incoming(), userId) 
                     && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email', 'educationLevel', 'updatedAt']);
    }

    function isValidUserProfile(data, userId) {
      return data.userId == userId
          && data.email is string
          && (!('displayName' in data) || data.displayName is string)
          && (!('educationLevel' in data) || data.educationLevel in ['10th', '12th'])
          && data.keys().hasAll(['userId', 'email']);
    }

    // Academic Records
    match /academic_records/{recordId} {
      allow list: if isDataOwner(resource.data);
      allow get: if isDataOwner(resource.data);
      allow create: if isDataOwner(incoming()) && isValidAcademicRecord(incoming());
      allow update: if isDataOwner(existing()) && isValidAcademicRecord(incoming())
                     && incoming().diff(existing()).affectedKeys().hasOnly(['marks', 'percentage', 'updatedAt']);
      allow delete: if isDataOwner(existing());
    }

    function isValidAcademicRecord(data) {
      return data.userId is string
          && data.standard in ['10th', '12th']
          && data.marks is map
          && data.keys().hasAll(['userId', 'standard', 'marks']);
    }

    // Recommendations
    match /recommendations/{recId} {
      allow list: if isDataOwner(resource.data);
      allow get: if isDataOwner(resource.data);
      allow create: if isDataOwner(incoming());
    }
  }
}
