rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(incoming());
      allow update: if isOwner(userId) && isValidUserProfile(incoming()) 
                     && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email', 'educationLevel', 'updatedAt']);
    }

    function isValidUserProfile(data) {
      return data.userId == request.auth.uid
          && data.email is string
          && (!('displayName' in data) || data.displayName is string)
          && (!('educationLevel' in data) || data.educationLevel in ['10th', '12th'])
          && data.keys().hasAll(['userId', 'email']);
    }

    // Academic Records
    match /academic_records/{recordId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidAcademicRecord(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && isValidAcademicRecord(incoming())
                     && incoming().diff(existing()).affectedKeys().hasOnly(['marks', 'percentage', 'updatedAt']);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    function isValidAcademicRecord(data) {
      return data.userId is string && data.userId == request.auth.uid
          && data.standard in ['10th', '12th']
          && data.marks is map
          && data.keys().hasAll(['userId', 'standard', 'marks']);
    }

    // Recommendations
    match /recommendations/{recId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      // Recommendations are system generated or at least based on analysis, usually read-only for user after creation
    }
  }
}
